{
  "name": "loci-lingua",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "agent": "cd services/agents && python -m uvicorn server:app --port 8000 --reload",
    "dev:all": "npx concurrently -k -n web,agent -c blue,green \"npm run dev\" \"npm run agent\"",
    "build": "next build",
    "start": "next start",
    "seed": "npx tsx src/lib/seed.ts",
    "build-prebuilt-worlds": "npx tsx scripts/build-prebuilt-worlds.ts",
    "upload-memory": "npx tsx scripts/upload-memory-to-render.ts",
    "test:e2e": "npx tsx scripts/e2e-integration-test.ts"
  },
  "dependencies": {
    "@copilotkit/react-core": "latest",
    "@copilotkit/react-ui": "latest",
    "@copilotkit/runtime": "^1.60.1",
    "@sparkjsdev/spark": "2.1.0",
    "framer-motion": "^11.0.0",
    "ioredis": "^5.4.0",
    "linkup-sdk": "latest",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "three": "0.180.0",
    "uuid": "^9.0.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/google.maps": "^3.65.1",
    "@types/node": "20.17.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.180.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
